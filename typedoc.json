{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "packages/core/src/index.ts",
    "packages/core/src/browser.ts",
    "packages/core/src/events/react.ts",
    "packages/core/src/validation/ed25519.ts",
    "packages/web/src/index.ts",
    "packages/bot/src/index.ts",
    "packages/bff/src/index.ts",
    "packages/ui/src/index.ts",
    "packages/ui/src/hooks/index.ts",
    "packages/devtools/src/index.ts"
  ],
  "entryPointStrategy": "resolve",
  "tsconfig": "tsconfig.typedoc.json",
  "out": "docs/api",
  "name": "Teleforge Documentation",
  "customCss": "docs/typedoc-sidebar.css",
  "customJs": "docs/typedoc-sidebar.js",
  "includeVersion": true,
  "disableGit": true,
  "disableSources": true,
  "excludeExternals": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "readme": "docs/site-home.md",
  "projectDocuments": [
    "docs/architecture.md",
    "docs/bff-guide.md",
    "docs/deployment.md",
    "docs/developer-guide.md",
    "docs/environment-variables.md",
    "docs/first-feature.md",
    "docs/flow-coordination.md",
    "docs/getting-started.md",
    "docs/manifest-reference.md",
    "docs/telegram-basics.md",
    "docs/testing.md",
    "docs/troubleshooting.md",
    "examples/starter-app/README.md",
    "apps/task-shop/README.md"
  ],
  "categorizeByGroup": true,
  "groupOrder": ["Classes", "Functions", "Interfaces", "Type Aliases", "Variables", "*"],
  "sort": ["source-order", "alphabetical"],
  "cleanOutputDir": true
}
