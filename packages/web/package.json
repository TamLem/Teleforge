{
  "name": "@teleforge/web",
  "version": "1.0.0",
  "description": "React hooks and types for Telegram WebApp integration.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "format": "prettier --check .",
    "lint": "eslint . --ext .ts,.tsx,.mjs",
    "prepublishOnly": "pnpm run build",
    "test": "pnpm run build && node --test test/*.mjs"
  },
  "dependencies": {
    "@teleforge/core": "workspace:1.0.0"
  },
  "peerDependencies": {
    "react": "^18.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "telegram",
    "mini-app",
    "react",
    "webapp",
    "hooks",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-test-renderer": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-test-renderer": "^18.3.1",
    "typescript": "^5.8.3"
  }
}
