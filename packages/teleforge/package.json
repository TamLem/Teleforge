{
  "name": "teleforge",
  "version": "0.1.0",
  "description": "Unified TypeScript framework package for Telegram-native apps.",
  "homepage": "https://tamlem.github.io/Teleforge/",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./bot": {
      "types": "./dist/bot.d.ts",
      "import": "./dist/bot.js",
      "require": "./dist/bot.cjs",
      "default": "./dist/bot.js"
    },
    "./bff": {
      "types": "./dist/bff.d.ts",
      "import": "./dist/bff.js",
      "require": "./dist/bff.cjs",
      "default": "./dist/bff.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs",
      "default": "./dist/core.js"
    },
    "./core/browser": {
      "types": "./dist/core-browser.d.ts",
      "import": "./dist/core-browser.js",
      "require": "./dist/core-browser.cjs",
      "default": "./dist/core-browser.js"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.js",
      "require": "./dist/devtools.cjs",
      "default": "./dist/devtools.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs",
      "default": "./dist/ui.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js",
      "require": "./dist/web.cjs",
      "default": "./dist/web.js"
    },
    "./server-hooks": {
      "types": "./dist/server-hooks.d.ts",
      "import": "./dist/server-hooks.js",
      "require": "./dist/server-hooks.cjs",
      "default": "./dist/server-hooks.js"
    }
  },
  "bin": {
    "teleforge": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "format": "prettier --check .",
    "lint": "eslint . --ext .ts,.mjs",
    "prepublishOnly": "pnpm run build",
    "test": "pnpm run build && node --test test/*.mjs"
  },
  "dependencies": {
    "@teleforgex/bff": "workspace:0.1.0",
    "@teleforgex/bot": "workspace:0.1.0",
    "@teleforgex/core": "workspace:0.1.0",
    "@teleforgex/devtools": "workspace:0.1.0",
    "@teleforgex/ui": "workspace:0.1.0",
    "@teleforgex/web": "workspace:0.1.0",
    "tsx": "^4.20.6"
  },
  "peerDependencies": {
    "react": "^18.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "telegram",
    "framework",
    "mini-app",
    "bot",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TamLem/Teleforge.git",
    "directory": "packages/teleforge"
  },
  "bugs": {
    "url": "https://github.com/TamLem/Teleforge/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "typescript": "^5.8.3"
  }
}
