{
  "name": "@teleforge/bff",
  "version": "1.0.0",
  "description": "Typed BFF route definitions and middleware for Teleforge.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./routes": {
      "types": "./dist/routes.d.ts",
      "import": "./dist/routes.js",
      "require": "./dist/routes.cjs",
      "default": "./dist/routes.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "format": "prettier --check .",
    "lint": "eslint . --ext .ts,.mjs",
    "prepublishOnly": "pnpm run build",
    "test": "pnpm run build && node --test test/*.mjs test/context/*.mjs test/identity/*.mjs test/route/*.mjs test/middleware/*.mjs test/session/*.mjs"
  },
  "dependencies": {
    "@teleforge/core": "workspace:1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "telegram",
    "bff",
    "backend-for-frontend",
    "routes",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
