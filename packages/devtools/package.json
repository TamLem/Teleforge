{
  "name": "@teleforge/devtools",
  "version": "0.5.0",
  "description": "Teleforge development CLI.",
  "homepage": "https://tamlem.github.io/Teleforge/",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./cli": {
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs",
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup --config tsup.config.ts",
    "format": "prettier --check .",
    "lint": "eslint . --ext .ts,.tsx,.mjs",
    "prepublishOnly": "pnpm run build",
    "test": "pnpm --filter create-teleforge-app build && pnpm run build && node --test --test-concurrency=1 test/cli.smoke.mjs test/doctor.mjs test/client-manifest-drift.mjs test/tunnel.mjs test/webhook.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@teleforge/core": "workspace:0.5.0",
    "http-proxy": "^1.18.1",
    "localtunnel": "^2.0.2",
    "qrcode-terminal": "^0.12.0",
    "selfsigned": "^3.0.1",
    "tsx": "^4.20.6"
  },
  "keywords": [
    "telegram",
    "mini-app",
    "cli",
    "devtools",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TamLem/Teleforge.git",
    "directory": "packages/devtools"
  },
  "bugs": {
    "url": "https://github.com/TamLem/Teleforge/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.16",
    "@types/node": "^24.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.8.3"
  },
  "private": true
}
