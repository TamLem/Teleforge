{
  "name": "@teleforge/devtools",
  "version": "1.0.0",
  "description": "Teleforge development CLI.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "teleforge": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "format": "prettier --check .",
    "lint": "eslint . --ext .ts,.tsx,.mjs",
    "prepublishOnly": "pnpm run build",
    "test": "pnpm --filter create-teleforge-app build && pnpm run build && node --test test/*.mjs"
  },
  "dependencies": {
    "@teleforge/core": "workspace:1.0.0",
    "http-proxy": "^1.18.1",
    "localtunnel": "^2.0.2",
    "qrcode-terminal": "^0.12.0",
    "selfsigned": "^3.0.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "telegram",
    "mini-app",
    "cli",
    "devtools",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.16",
    "@types/node": "^24.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.8.3"
  }
}
