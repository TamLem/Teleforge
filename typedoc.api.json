{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "packages/teleforge/src/index.ts",
    "packages/teleforge/src/web.ts",
    "packages/teleforge/src/ui.ts",
    "packages/teleforge/src/bot.ts",
    "packages/teleforge/src/core-browser.ts",
    "packages/teleforge/src/server-hooks-entry.ts"
  ],
  "entryPointStrategy": "resolve",
  "tsconfig": "tsconfig.typedoc.json",
  "out": "dist/docs-site/api",
  "name": "Teleforge API Reference",
  "includeVersion": true,
  "disableGit": true,
  "disableSources": true,
  "excludeExternals": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "readme": "none",
  "categorizeByGroup": true,
  "groupOrder": ["Classes", "Functions", "Interfaces", "Type Aliases", "Variables", "*"],
  "sort": ["source-order", "alphabetical"],
  "cleanOutputDir": false
}
