{
  "$schema": "https://teleforge.dev/schemas/app-manifest.json",
  "id": "starter-app",
  "name": "Starter App",
  "version": "1.0.0",
  "runtime": {
    "mode": "spa",
    "webFramework": "vite",
    "build": {
      "outDir": "dist",
      "basePath": "/"
    }
  },
  "bot": {
    "username": "starter_app_bot",
    "tokenEnv": "BOT_TOKEN",
    "webhook": {
      "path": "/api/webhook",
      "secretEnv": "WEBHOOK_SECRET"
    },
    "commands": [
      {
        "command": "start",
        "description": "Open the Starter App",
        "handler": "commands/start"
      }
    ]
  },
  "miniApp": {
    "entryPoint": "apps/web/src/main.tsx",
    "launchModes": ["inline", "compact", "fullscreen"],
    "defaultMode": "inline",
    "capabilities": ["read_access"]
  },
  "routes": [
    {
      "path": "/",
      "component": "App",
      "launchModes": ["inline", "compact", "fullscreen"]
    }
  ]
}
