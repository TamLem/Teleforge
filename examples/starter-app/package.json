{
  "name": "teleforge-starter-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build:bot": "tsc -p apps/bot/tsconfig.json",
    "build:web": "cd apps/web && vite build",
    "dev": "teleforge dev --open",
    "dev:bot": "tsx watch apps/bot/src/index.ts",
    "dev:public": "teleforge dev --public --live",
    "doctor": "teleforge doctor"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "teleforge": "link:../../packages/teleforge"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vite": "^5.4.10"
  }
}
