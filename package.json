{
  "name": "teleforge",
  "private": true,
  "version": "0.1.0",
  "description": "Telegram-native full-stack framework.",
  "homepage": "https://tamlem.github.io/Teleforge/",
  "packageManager": "pnpm@10.15.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TamLem/Teleforge.git"
  },
  "bugs": {
    "url": "https://github.com/TamLem/Teleforge/issues"
  },
  "workspaces": [
    "apps/task-shop",
    "apps/task-shop/apps/*",
    "apps/task-shop/packages/*",
    "packages/*",
    "benchmark",
    "examples/*"
  ],
  "scripts": {
    "analyze": "pnpm build && pnpm --dir benchmark analyze",
    "bench": "pnpm --dir benchmark bench",
    "bench:ci": "pnpm --dir benchmark bench:ci",
    "build": "pnpm --filter '@teleforgex/*' --filter '!@teleforgex/task-shop' build && pnpm --filter create-teleforge-app build && pnpm --dir apps/task-shop build",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "check": "pnpm lint && pnpm format && pnpm test && pnpm build",
    "docs:build": "pnpm docs:clean && node scripts/build-docs-site.mjs && typedoc --options typedoc.api.json",
    "docs:build:api": "typedoc --options typedoc.api.json",
    "docs:build:site": "node scripts/build-docs-site.mjs",
    "docs:clean": "rm -rf dist/docs-site",
    "docs:serve": "pnpm exec serve dist/docs-site --listen 4173",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs",
    "lint:fix": "eslint . --fix --ext .ts,.tsx,.js,.mjs,.cjs",
    "publish": "node scripts/release-publish.mjs",
    "publish:dry-run": "node scripts/release-publish.mjs --dry-run",
    "size": "pnpm --dir benchmark size",
    "test": "pnpm --filter '@teleforgex/*' --filter '!@teleforgex/task-shop' test && pnpm --filter create-teleforge-app test && pnpm --dir apps/task-shop test",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.31.0",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "prettier": "^3.5.3",
    "serve": "^14.2.4",
    "tsup": "^8.5.0",
    "typedoc": "^0.28.14",
    "typescript": "^5.9.3"
  }
}
