{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "paths": {
      "@teleforge/bot": ["packages/bot/src/index.ts"],
      "@teleforge/core": ["packages/core/src/index.ts"],
      "@teleforge/core/browser": ["packages/core/src/browser.ts"],
      "@teleforge/core/react": ["packages/core/src/events/react.ts"],
      "@teleforge/core/validation/ed25519": ["packages/core/src/validation/ed25519.ts"],
      "@teleforge/ui": ["packages/ui/src/index.ts"],
      "teleforge": ["packages/teleforge/src/index.ts"],
      "teleforge/bot": ["packages/teleforge/src/bot.ts"],
      "teleforge/core": ["packages/teleforge/src/core.ts"],
      "teleforge/web": ["packages/teleforge/src/web.ts"],
      "@teleforge/web": ["packages/web/src/index.ts"]
    }
  },
  "include": [
    "packages/core/src/**/*.ts",
    "packages/web/src/**/*.ts",
    "packages/web/src/**/*.tsx",
    "packages/bot/src/**/*.ts",
    "packages/ui/src/**/*.ts",
    "packages/ui/src/**/*.tsx",
    "packages/devtools/src/**/*.ts",
    "packages/teleforge/src/**/*.ts"
  ]
}
